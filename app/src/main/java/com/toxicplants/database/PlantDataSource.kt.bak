            PlantEntity(id = 71, commonName = "Cicuta acuática", scientificName = "Cicuta virosa", family = "Apiaceae", toxicityLevel = "Mortal", toxicParts = "Raíz", symptoms = "Convulsiones violentas, status epilepticus, muerte.", description = "Planta acuática con raíz hueca tabicada.", habitat = "Humedales.", geographicDistribution = "Europa, Asia.", firstAid = "EMERGENCIA. Benzodiazepinas para convulsiones. UCI.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/2/29/Cicuta_virosa_-_Köhler–s_Medizinal-Pflanzen-191.jpg/800px-Cicuta_virosa.jpg", category = "Acuática"),

            PlantEntity(id = 72, commonName = "Perejil gigante / Heracleo", scientificName = "Heracleum mantegazzianum", family = "Apiaceae", toxicityLevel = "Alta", toxicParts = "Savia", symptoms = "Fotodermatitis severa, ampollas, quemaduras de 2° y 3° grado, cicatrices permanentes, ceguera.", description = "Planta herbácea gigante de hasta 5m de alto con umbelas enormes.", habitat = "Bordes de ríos, terrenos baldíos.", geographicDistribution = "Cáucaso. Invasora en Europa y Norteamérica.", firstAid = "Lavar inmediatamente con agua. Evitar exposición solar. Dermatología urgente.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/c/c1/Heracleum_mantegazzianum_Giessen_2009.jpg/800px-Heracleum_mantegazzianum.jpg", category = "Silvestre"),

            PlantEntity(id = 73, commonName = "Árbol de las salchichas", scientificName = "Kigelia africana", family = "Bignoniaceae", toxicityLevel = "Alta", toxicParts = "Frutos frescos", symptoms = "Ampollas en piel, úlceras, vómitos severos, diarrea.", description = "Árbol con frutos colgantes que parecen salchichas de hasta 60cm.", habitat = "Sabanas africanas.", geographicDistribution = "África tropical.", firstAid = "No consumir frutos frescos. Buscar atención médica.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/a/a7/Kigelia_africana_fruits.jpg/800px-Kigelia_africana.jpg", category = "Silvestre"),

            PlantEntity(id = 74, commonName = "Tártago", scientificName = "Euphorbia lathyris", family = "Euphorbiaceae", toxicityLevel = "Alta", toxicParts = "Semillas y savia", symptoms = "Quemaduras en piel y mucosas, vómitos violentos, diarrea, colapso.", description = "Planta herbácea bienal con hojas opuestas y savia lechosa irritante.", habitat = "Jardines, terrenos baldíos.", geographicDistribution = "Sur de Europa y Asia.", firstAid = "Lavar piel. No ingerir semillas como purgante. Hospitalización si hay síntomas severos.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/d/d2/Euphorbia_lathyris_001.jpg/800px-Euphorbia_lathyris.jpg", category = "Silvestre"),

            PlantEntity(id = 75, commonName = "Abro / Regaliz americano", scientificName = "Abrus precatorius", family = "Fabaceae", toxicityLevel = "Mortal", toxicParts = "Semillas (abrina, más tóxica que la ricina)", symptoms = "Vómitos, diarrea con sangre, fallo renal y hepático, convulsiones, muerte. Una sola semilla masticada puede matar.", description = "Trepadora con semillas rojas con punto negro, usadas en bisutería.", habitat = "Zonas tropicales.", geographicDistribution = "Pan-tropical.", firstAid = "EMERGENCIA MÁXIMA. Hospitalización UCI inmediata. No hay antídoto.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/4/4a/Abrus_precatorius_pods.jpg/800px-Abrus_precatorius.jpg", category = "Silvestre"),

            PlantEntity(id = 76, commonName = "Ojo de buey", scientificName = "Mucuna pruriens", family = "Fabaceae", toxicityLevel = "Media", toxicParts = "Pelos de las vainas", symptoms = "Prurito intenso, dermatitis severa, irritación de ojos y vías respiratorias.", description = "Trepadora tropical con vainas cubiertas de pelos urticantes anaranjados.", habitat = "Selvas tropicales.", geographicDistribution = "Trópicos de ambos hemisferios.", firstAid = "No rascarse. Retirar pelos con cinta adhesiva. Antihistamínicos. Lavar con agua.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/a/ac/Mucuna_pruriens_flowers.jpg/800px-Mucuna_pruriens.jpg", category = "Silvestre"),

            PlantEntity(id = 77, commonName = "Cerbera / Árbol suicida", scientificName = "Cerbera manghas", family = "Apocynaceae", toxicityLevel = "Mortal", toxicParts = "Semillas (cerberina)", symptoms = "Arritmias cardíacas fatales. Usado como método de suicidio y asesinato en India.", description = "Árbol costero con flores blancas fragantes y frutos similares a mangos.", habitat = "Costas tropicales.", geographicDistribution = "Costas del Océano Índico y Pacífico.", firstAid = "EMERGENCIA CARDÍACA. UCI. Anticuerpos anti-digoxina. Marcapasos temporal.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/e/ee/Cerbera_manghas_flower.jpg/800px-Cerbera_manghas.jpg", category = "Silvestre"),

            PlantEntity(id = 78, commonName = "Agave", scientificName = "Agave americana", family = "Asparagaceae", toxicityLevel = "Media", toxicParts = "Savia, espinas", symptoms = "Dermatitis severa, irritación cutánea con savia, heridas por espinas. Irritación gástrica si se ingiere.", description = "Suculenta grande con roseta de hojas gruesas espinosas azul-verdosas.", habitat = "Jardines, terrenos secos.", geographicDistribution = "México. Naturalizada en Mediterráneo.", firstAid = "Lavar piel con agua y jabón. Tratar heridas por espinas. Antihistamínicos para dermatitis.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/4/4b/Agave_americana_R01.jpg/800px-Agave_americana.jpg", category = "Jardín"),

            PlantEntity(id = 79, commonName = "Dafne / Laureola", scientificName = "Daphne mezereum", family = "Thymelaeaceae", toxicityLevel = "Mortal", toxicParts = "Bayas y corteza", symptoms = "Quemaduras en boca, vómitos con sangre, diarrea hemorrágica, fallo renal, muerte.", description = "Arbusto caducifolio con flores rosas fragantes antes de las hojas y bayas rojas.", habitat = "Bosques montañosos.", geographicDistribution = "Europa y Asia.", firstAid = "EMERGENCIA. No inducir vómito (por quemaduras). Hospitalización inmediata.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/9/98/Daphne_mezereum_flowers.jpg/800px-Daphne_mezereum.jpg", category = "Silvestre"),

            PlantEntity(id = 80, commonName = "Brugmansia roja", scientificName = "Brugmansia sanguinea", family = "Solanaceae", toxicityLevel = "Mortal", toxicParts = "Todas las partes", symptoms = "Delirio anticolinérgico, alucinaciones, hipertermia, convulsiones, muerte.", description = "Arbusto con flores tubulares rojo-anaranjadas pendulares.", habitat = "Jardines de altura tropicales.", geographicDistribution = "Andes sudamericanos.", firstAid = "EMERGENCIA. Fisostigmina. Benzodiazepinas. UCI.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/8/8a/Brugmansia_sanguinea1.jpg/800px-Brugmansia_sanguinea.jpg", category = "Jardín"),

            // ===== PLANTAS 81-100 =====
            PlantEntity(id = 81, commonName = "Hemlock acuática", scientificName = "Cicuta maculata", family = "Apiaceae", toxicityLevel = "Mortal", toxicParts = "Raíz", symptoms = "Convulsiones violentas en minutos, status epilepticus, muerte.", description = "Planta acuática norteamericana, la planta más tóxica de Norteamérica.", habitat = "Humedales, bordes de ríos.", geographicDistribution = "América del Norte.", firstAid = "EMERGENCIA. Benzodiazepinas IV para convulsiones. UCI.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/c/c2/Cicuta_maculata.jpg/800px-Cicuta_maculata.jpg", category = "Acuática"),

            PlantEntity(id = 82, commonName = "Zamia", scientificName = "Zamia furfuracea", family = "Zamiaceae", toxicityLevel = "Alta", toxicParts = "Todas las partes, especialmente semillas", symptoms = "Vómitos, diarrea, daño hepático severo, hemorragias.", description = "Planta similar a una palma primitiva con hojas pinnadas rígidas.", habitat = "Jardines, interiores.", geographicDistribution = "México.", firstAid = "Hospitalización. Monitorización hepática.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/e/e2/Zamia_furfuracea01.jpg/800px-Zamia_furfuracea.jpg", category = "Doméstica"),

            PlantEntity(id = 83, commonName = "Acacia falsa / Robinia", scientificName = "Robinia pseudoacacia", family = "Fabaceae", toxicityLevel = "Alta", toxicParts = "Corteza, semillas, raíces", symptoms = "Náuseas, vómitos, diarrea, somnolencia, debilidad. Grandes cantidades: convulsiones.", description = "Árbol caducifolio con racimos de flores blancas fragantes y espinas.", habitat = "Parques, calles, bosques secundarios.", geographicDistribution = "Este de Norteamérica. Naturalizada mundialmente.", firstAid = "Inducir vómito. Carbón activado. Hospitalización si hay síntomas neurológicos.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/1/15/Robinia_pseudoacacia_flowers.jpg/800px-Robinia_pseudoacacia.jpg", category = "Jardín"),

