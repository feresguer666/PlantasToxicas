            PlantEntity(id = 85, commonName = "Oreja de elefante", scientificName = "Colocasia esculenta (silvestre)", family = "Araceae", toxicityLevel = "Alta", toxicParts = "Hojas y tubérculos crudos", symptoms = "Irritación intensa de boca, hinchazón de garganta, dificultad para respirar.", description = "Planta con enormes hojas acorazonadas. Los tubérculos se comen cocidos (taro) pero son tóxicos crudos.", habitat = "Zonas húmedas tropicales.", geographicDistribution = "Sudeste asiático. Pantropical.", firstAid = "Lavar boca. Compresas frías. EMERGENCIA si hay hinchazón de vías aéreas.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/d/da/Taro_%28Colocasia_esculenta%29.jpg/800px-Colocasia_esculenta.jpg", category = "Doméstica"),

            PlantEntity(id = 86, commonName = "Flor del tabaco", scientificName = "Nicotiana alata", family = "Solanaceae", toxicityLevel = "Alta", toxicParts = "Todas las partes", symptoms = "Similar a intoxicación por nicotina: náuseas, vómitos, taquicardia, convulsiones.", description = "Planta ornamental con flores tubulares fragantes que abren por la noche.", habitat = "Jardines.", geographicDistribution = "Brasil. Cultivada mundialmente.", firstAid = "Inducir vómito. Hospitalización si hay síntomas cardíacos.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/c/c5/Nicotiana_alata1.jpg/800px-Nicotiana_alata.jpg", category = "Jardín"),

