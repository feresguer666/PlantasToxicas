            PlantEntity(id = 55, commonName = "Nuez vómica", scientificName = "Strychnos nux-vomica", family = "Loganiaceae", toxicityLevel = "Mortal", toxicParts = "Semillas (estricnina)", symptoms = "Espasmos musculares violentos, opistótonos, convulsiones tetánicas, muerte por agotamiento o asfixia.", description = "Árbol mediano con frutos esféricos anaranjados que contienen semillas con estricnina.", habitat = "Bosques tropicales.", geographicDistribution = "India, sudeste asiático, Australia.", firstAid = "EMERGENCIA MÁXIMA. Sedación con diazepam. Ventilación mecánica. UCI.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/a/aa/Strychnos_nux-vomica_-_Köhler–s_Medizinal-Pflanzen-233.jpg/800px-Strychnos_nux-vomica.jpg", category = "Silvestre"),

            PlantEntity(id = 56, commonName = "Eléboro negro", scientificName = "Helleborus niger", family = "Ranunculaceae", toxicityLevel = "Alta", toxicParts = "Todas las partes, especialmente raíces", symptoms = "Vértigo, estupor, tinnitus, vómitos violentos, bradicardia, colapso.", description = "Planta perenne que florece en invierno con flores blancas que se tornan rosadas. Llamada 'rosa de Navidad'.", habitat = "Jardines, bosques montañosos.", geographicDistribution = "Europa central y meridional.", firstAid = "Inducir vómito. Carbón activado. Hospitalización.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/2/25/Helleborus_niger_1.jpg/800px-Helleborus_niger.jpg", category = "Jardín"),

            PlantEntity(id = 57, commonName = "Colchico / Azafrán silvestre", scientificName = "Colchicum autumnale", family = "Colchicaceae", toxicityLevel = "Mortal", toxicParts = "Todas las partes (colchicina)", symptoms = "Vómitos, diarrea con sangre, fallo multiorgánico, supresión de médula ósea, muerte en 7-10 días.", description = "Planta bulbosa que florece en otoño sin hojas, con flores rosas o púrpuras similares al azafrán.", habitat = "Prados húmedos.", geographicDistribution = "Europa, norte de África.", firstAid = "EMERGENCIA. No hay antídoto. Hospitalización UCI. Lavado gástrico si fue muy reciente.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/9/92/Colchicum_autumnale_01.jpg/800px-Colchicum_autumnale_01.jpg", category = "Silvestre"),

            PlantEntity(id = 58, commonName = "Jazmín amarillo / Carolina", scientificName = "Gelsemium sempervirens", family = "Gelsemiaceae", toxicityLevel = "Mortal", toxicParts = "Todas las partes, incluyendo el néctar", symptoms = "Debilidad muscular, caída de párpados, visión doble, dificultad respiratoria, parálisis, muerte.", description = "Trepadora perenne con flores amarillas fragantes en forma de embudo.", habitat = "Bosques, jardines.", geographicDistribution = "Sureste de EE.UU., México, Guatemala.", firstAid = "EMERGENCIA. Hospitalización. Soporte respiratorio. No consumir miel de esta planta.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/6/6f/Gelsemium_sempervirens2.jpg/800px-Gelsemium_sempervirens2.jpg", category = "Jardín"),

            PlantEntity(id = 59, commonName = "Cólquico", scientificName = "Gloriosa superba", family = "Colchicaceae", toxicityLevel = "Mortal", toxicParts = "Todas las partes, especialmente tubérculos", symptoms = "Similar a Colchicum. Fallo multiorgánico, coagulación intravascular diseminada, muerte.", description = "Trepadora con flores espectaculares de pétalos reflexos rojos y amarillos, ondulados.", habitat = "Jardines tropicales.", geographicDistribution = "África tropical y Asia.", firstAid = "EMERGENCIA. Hospitalización inmediata UCI.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/5/5d/Gloriosa_superba_002.JPG/800px-Gloriosa_superba.jpg", category = "Jardín"),

            PlantEntity(id = 60, commonName = "Beleño", scientificName = "Hyoscyamus niger", family = "Solanaceae", toxicityLevel = "Mortal", toxicParts = "Todas las partes", symptoms = "Pupilas dilatadas, sequedad de boca, alucinaciones, delirio, taquicardia, convulsiones, coma, muerte.", description = "Planta herbácea con hojas pegajosas y flores amarillentas con venas púrpuras. Olor desagradable.", habitat = "Terrenos baldíos, ruinas, bordes de caminos.", geographicDistribution = "Europa, Asia, norte de África.", firstAid = "EMERGENCIA. Fisostigmina como antídoto. Hospitalización.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/e/e5/Hyoscyamus_niger_-_Köhler–s_Medizinal-Pflanzen-078.jpg/800px-Hyoscyamus_niger.jpg", category = "Silvestre"),

            // ===== PLANTAS 61-100 =====
            PlantEntity(id = 61, commonName = "Hierba de San Cristóbal", scientificName = "Actaea spicata", family = "Ranunculaceae", toxicityLevel = "Alta", toxicParts = "Bayas y raíces", symptoms = "Irritación de boca, vómitos, diarrea, alucinaciones, convulsiones.", description = "Planta herbácea con racimos de bayas negras brillantes.", habitat = "Bosques húmedos, montañas.", geographicDistribution = "Europa, Asia.", firstAid = "Inducir vómito. Hospitalización si hay síntomas neurológicos.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/b/b7/Actaea_spicata_kz01.jpg/800px-Actaea_spicata.jpg", category = "Silvestre"),

            PlantEntity(id = 62, commonName = "Cólquido del cabo", scientificName = "Ornithogalum thyrsoides", family = "Asparagaceae", toxicityLevel = "Alta", toxicParts = "Bulbo", symptoms = "Vómitos, diarrea, bradicardia, arritmias.", description = "Planta bulbosa con racimos de flores blancas estrelladas.", habitat = "Jardines.", geographicDistribution = "Sudáfrica.", firstAid = "No consumir el bulbo. Hospitalización si se ingirió.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/f/f6/Ornithogalum_thyrsoides.jpg/800px-Ornithogalum_thyrsoides.jpg", category = "Jardín"),

            PlantEntity(id = 63, commonName = "Retama negra", scientificName = "Cytisus scoparius", family = "Fabaceae", toxicityLevel = "Alta", toxicParts = "Semillas, flores, tallos", symptoms = "Náuseas, vómitos, taquicardia, hipotensión, convulsiones, parálisis respiratoria.", description = "Arbusto con ramas verdes y flores amarillas papilionáceas.", habitat = "Terrenos ácidos, bordes de caminos.", geographicDistribution = "Europa occidental.", firstAid = "Inducir vómito. Carbón activado. Hospitalización.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/1/1d/Cytisus_scoparius.jpg/800px-Cytisus_scoparius.jpg", category = "Silvestre"),

            PlantEntity(id = 64, commonName = "Euforbia candelabro", scientificName = "Euphorbia ingens", family = "Euphorbiaceae", toxicityLevel = "Alta", toxicParts = "Savia lechosa (látex)", symptoms = "Quemaduras químicas en piel, ceguera si contacta ojos, vómitos si se ingiere.", description = "Suculenta arbórea de gran tamaño con forma de candelabro, sin hojas aparentes.", habitat = "Jardines xerófitos.", geographicDistribution = "Sur y este de África.", firstAid = "Lavar abundantemente con agua. Si afecta ojos, irrigación continua y oftalmólogo urgente.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/d/d7/Euphorbia_ingens_01.jpg/800px-Euphorbia_ingens.jpg", category = "Jardín"),

            PlantEntity(id = 65, commonName = "Sabina", scientificName = "Juniperus sabina", family = "Cupressaceae", toxicityLevel = "Mortal", toxicParts = "Hojas y brotes (aceite esencial)", symptoms = "Hemorragias uterinas, aborto, daño renal severo, convulsiones, muerte.", description = "Arbusto conífero postrado con follaje escamoso de olor fuerte.", habitat = "Montañas rocosas, jardines.", geographicDistribution = "Montañas de Europa y Asia.", firstAid = "EMERGENCIA. Hospitalización. NUNCA usar como abortivo (extremadamente peligroso).", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/1/1b/Juniperus_sabina1.jpg/800px-Juniperus_sabina.jpg", category = "Jardín"),

            PlantEntity(id = 66, commonName = "Cáñamo indio", scientificName = "Cannabis sativa", family = "Cannabaceae", toxicityLevel = "Media", toxicParts = "Flores y hojas (THC)", symptoms = "Alteraciones de percepción, ansiedad, taquicardia, hipotensión ortostática, paranoia. En niños: coma.", description = "Planta herbácea dioica con hojas palmadas compuestas.", habitat = "Cultivos, terrenos baldíos.", geographicDistribution = "Originaria de Asia Central. Cosmopolita.", firstAid = "En niños es EMERGENCIA. En adultos: ambiente tranquilo, hidratación. Benzodiacepinas si ansiedad severa.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/f/f1/Cannabis_sativa_001.JPG/800px-Cannabis_sativa.jpg", category = "Agrícola"),

            PlantEntity(id = 67, commonName = "Laburo / Lluvia de oro", scientificName = "Laburnum anagyroides", family = "Fabaceae", toxicityLevel = "Mortal", toxicParts = "Todas las partes, especialmente semillas", symptoms = "Vómitos, excitación seguida de somnolencia, convulsiones, coma, parálisis respiratoria, muerte.", description = "Árbol pequeño con racimos colgantes de flores amarillas muy vistosas. Las semillas parecen guisantes.", habitat = "Jardines, parques.", geographicDistribution = "Europa central y meridional.", firstAid = "EMERGENCIA. Hospitalización. Lavado gástrico. Carbón activado. Soporte respiratorio.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/f/f4/Laburnum_anagyroides.jpg/800px-Laburnum_anagyroides.jpg", category = "Jardín"),

            PlantEntity(id = 68, commonName = "Tuya", scientificName = "Thuja occidentalis", family = "Cupressaceae", toxicityLevel = "Alta", toxicParts = "Hojas y aceite esencial (tuyona)", symptoms = "Convulsiones, vómitos, diarrea, daño hepático y renal. Aborto.", description = "Conífera perenne con follaje escamoso, muy usada en setos.", habitat = "Jardines, setos.", geographicDistribution = "América del Norte. Cultivada mundialmente.", firstAid = "No ingerir ni usar aceite esencial internamente. Hospitalización si hay convulsiones.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/1/1f/Thuja_occidentalis_01.jpg/800px-Thuja_occidentalis.jpg", category = "Jardín"),

            PlantEntity(id = 69, commonName = "Adelfa amarilla", scientificName = "Thevetia peruviana", family = "Apocynaceae", toxicityLevel = "Mortal", toxicParts = "Todas las partes, especialmente semillas", symptoms = "Arritmias cardíacas severas, bradicardia, bloqueo AV, vómitos, muerte.", description = "Arbusto con flores amarillas tubulares y hojas lineares. Similar a la adelfa pero con flores amarillas.", habitat = "Jardines tropicales.", geographicDistribution = "México, América Central. Cultivada en trópicos.", firstAid = "EMERGENCIA CARDÍACA. Anticuerpos anti-digoxina. UCI con monitorización.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/c/c3/Thevetia_peruviana_flowers.jpg/800px-Thevetia_peruviana.jpg", category = "Jardín"),

            PlantEntity(id = 70, commonName = "Jacinto", scientificName = "Hyacinthus orientalis", family = "Asparagaceae", toxicityLevel = "Media", toxicParts = "Bulbo principalmente", symptoms = "Dermatitis de contacto, náuseas, vómitos, diarrea si se ingiere el bulbo.", description = "Planta bulbosa con racimos densos de flores fragantes en muchos colores.", habitat = "Jardines, interiores.", geographicDistribution = "Mediterráneo oriental. Cultivada mundialmente.", firstAid = "Usar guantes al manipular bulbos. Si se ingirió, inducir vómito.", imageUrl = "https://upload.wikimedia.org/wikipedia/commons/thumb/5/56/Hyacinthus_orientalis0.jpg/800px-Hyacinthus_orientalis0.jpg", category = "Jardín"),

